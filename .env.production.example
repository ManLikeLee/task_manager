# TaskForce Production Environment Configuration
# Copy this file to .env on your production server or Vercel deployment

# Node environment (REQUIRED for production error handling)
NODE_ENV=production

# Database
# REQUIRED: PostgreSQL connection string
# Example: postgresql://user:password@host:5432/database?schema=public
DATABASE_URL="postgresql://user:password@db-host.example.com:5432/task_manager?schema=public"

# Authentication
# REQUIRED: JWT signing secrets (use strong, random values)
JWT_ACCESS_SECRET=your-very-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-very-long-random-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# REQUIRED: Frontend URL for CORS policy (production domain)
CLIENT_URL=https://yourdomain.com

# Cookies
# REQUIRED for production: allow cross-origin requests
COOKIE_SECURE=true
COOKIE_SAMESITE=none
# COOKIE_DOMAIN=yourdomain.com  # Optional: uncomment for subdomain cookies

# Server Port
PORT=4050

# Email Delivery
# Production requires real email verification setup
EMAIL_PROVIDER=smtp
EMAIL_FROM="TaskForce <no-reply@yourdomain.com>"

# For SMTP (e.g., Gmail, SendGrid, custom)
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=your-email@provider.com
SMTP_PASS=your-smtp-password

# OR: For Resend (https://resend.com)
# RESEND_API_KEY=your-resend-api-key

# Email Verification
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
