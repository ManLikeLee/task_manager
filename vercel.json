{
  "name": "task-manager",
  "version": 2,
  "buildCommand": "npm install && npm run build:client",
  "outputDirectory": "client/dist",
  "env": {
    "NODE_ENV": "production",
    "COOKIE_SECURE": "true",
    "COOKIE_SAMESITE": "none"
  },
  "functions": {
    "server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/dist/index.html"
    }
  ]
}
