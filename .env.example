PORT=4050
NODE_ENV=development
CLIENT_URL=http://localhost:3000
DATABASE_URL="postgresql://mac@localhost:5432/task_manager?schema=public"
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SAMESITE=strict
COOKIE_SECURE=false
# COOKIE_DOMAIN=example.com

# Email verification
# Required for real email delivery in production/staging.
EMAIL_PROVIDER=smtp
EMAIL_FROM="TaskForce <no-reply@taskforce.app>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=
TEST_EMAIL_TO=
EMAIL_VERIFICATION_CODE_TTL_MINUTES=15
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
